# Required - Get free at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Optional - Increases rate limits for embeddings
# Get free at https://huggingface.co/settings/tokens
HF_API_KEY=

# Optional - Session secret for authentication (auto-generated if not set)
SESSION_SECRET=your-secure-random-string

PORT=3000
